# Share file manager — protezioni di base
Options -Indexes
DirectoryIndex index.php

# Blocca l'accesso diretto a file sensibili
<FilesMatch "\.(json|md|log|txt)$">
  Require all denied
</FilesMatch>
# I moduli interni sono include, non endpoint: solo index.php, api.php e share.php
# vanno raggiunti via HTTP. Blocca config, lib*, api_*, storage, oidc.
<FilesMatch "^(config|lib|lib_[a-z]+|api_[a-z]+|storage|oidc)\.php$">
  Require all denied
</FilesMatch>

# Link di condivisione "belli": /d/<slug> → share.php?t=<slug>
# Namespace dedicato: non oscura file o cartelle reali (che stanno nella root).
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^d/([A-Za-z0-9][A-Za-z0-9_-]{0,63})$ share.php?t=$1 [L,QSA]
</IfModule>
