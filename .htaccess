# Share file manager — protezioni di base
Options -Indexes
DirectoryIndex index.php

# Blocca l'accesso diretto a file sensibili
<FilesMatch "\.(json|md|log)$">
  Require all denied
</FilesMatch>
<FilesMatch "^(config|lib)\.php$">
  Require all denied
</FilesMatch>

# Link di condivisione "belli": /d/<slug> → share.php?t=<slug>
# Namespace dedicato: non oscura file o cartelle reali (che stanno nella root).
# /c/ è mantenuto come alias legacy (link generati prima del passaggio a /d/).
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^[dc]/([A-Za-z0-9][A-Za-z0-9_-]{0,63})$ share.php?t=$1 [L,QSA]
</IfModule>
